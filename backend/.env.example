MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=yourapp@gmail.com
MAIL_PASS=your_app_password_here # DO NOT USE your regular Gmail password, generate an App Password instead (see instructions below)
MAIL_FROM="Organic Editorial <yourapp@gmail.com>"
# Step 1 — Enable 2-Step Verification (required first)

# Go to myaccount.google.com
# Click Security on the left
# Under "How you sign in to Google", click 2-Step Verification
# Follow the steps to turn it on


# Step 2 — Generate an App Password

# Go to myaccount.google.com/apppasswords (or search "App Passwords" in your Google account)
# Under "App name", type anything like NestJS Mailer
# Click Create
# Google shows you a 16-character password like abcd efgh ijkl mnop